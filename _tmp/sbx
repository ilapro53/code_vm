#!/bin/bash
# sbx — fakeroot/fakechroot Debian-сэндбокс (apt без root)
# Поддержка нескольких sandbox'ов через -n <имя>
#
# Использование:
#   sbx <команда>                       — default sandbox
#   sbx -n <имя> <команда>             — именованный sandbox
#   sbx --init [<имя>]                  — создать sandbox (по умолчанию "sandbox")
#   sbx --rm <имя>                      — удалить sandbox
#   sbx --list                          — список sandbox'ов
#   sbx --status [<имя>]                — размер и статус
#
# Примеры:
#   sbx apt update
#   sbx -n web apt install -y nginx
#   sbx -n web /usr/sbin/nginx -v
#   sbx --init ml                       — создать sandbox "ml"
#   sbx --rm web                        — удалить sandbox "web"
#   sbx --list                          — показать все sandbox'ы
#   sbx --rm-all                        — удалить все sandbox'ы

SANDBOX_DIR="$HOME"

usage() {
    cat <<'EOF'
sbx — Multiple fakeroot/fakechroot Debian sandboxes

Usage:
  sbx <command> [args]          Run command in default sandbox
  sbx -n <name> <command>       Run command in named sandbox
  sbx --init [<name>]           Create sandbox (default name: "sandbox")
  sbx --rm <name>               Remove a sandbox
  sbx --rm-all                  Remove all sandboxes
  sbx --list                    List all sandboxes
  sbx --status [<name>]         Show sandbox size and status

Examples:
  sbx apt update
  sbx -n web apt install -y nginx
  sbx --init ml
  sbx --rm web
  sbx --list
EOF
}

get_sandbox_path() {
    local name="${1:-sandbox}"
    echo "$SANDBOX_DIR/$name"
}

init_sandbox() {
    local name="${1:-sandbox}"
    local path=$(get_sandbox_path "$name")

    if [ -d "$path/etc" ]; then
        echo "Sandbox '$name' already exists at $path"
        return 0
    fi

    echo "Creating sandbox '$name' at $path..."
    fakeroot fakechroot debootstrap --variant=fakechroot bookworm "$path" http://deb.debian.org/debian/
    if [ $? -eq 0 ]; then
        echo "Sandbox '$name' created successfully."
    else
        echo "Failed to create sandbox '$name'."
        return 1
    fi
}

rm_sandbox() {
    local name="$1"
    if [ -z "$name" ]; then
        echo "Usage: sbx --rm <name>"
        return 1
    fi
    local path=$(get_sandbox_path "$name")

    if [ ! -d "$path" ]; then
        echo "Sandbox '$name' not found."
        return 1
    fi

    echo "Removing sandbox '$name' at $path..."
    rm -rf "$path"
    echo "Sandbox '$name' removed."
}

rm_all_sandboxes() {
    local count=0
    for dir in "$SANDBOX_DIR"/*/; do
        if [ -d "$dir/etc" ] && [ -f "$dir/etc/debian_version" ]; then
            local name=$(basename "$dir")
            echo "Removing sandbox '$name'..."
            rm -rf "$dir"
            count=$((count + 1))
        fi
    done
    echo "Removed $count sandbox(es)."
}

list_sandboxes() {
    echo "Available sandboxes in $SANDBOX_DIR:"
    echo "---"
    local found=0
    for dir in "$SANDBOX_DIR"/*/; do
        if [ -d "$dir/etc" ] && [ -f "$dir/etc/debian_version" ]; then
            local name=$(basename "$dir")
            local size=$(du -sh "$dir" 2>/dev/null | cut -f1)
            local version=$(cat "$dir/etc/debian_version" 2>/dev/null)
            printf "  %-20s %6s  Debian %s\n" "$name" "$size" "$version"
            found=1
        fi
    done
    if [ $found -eq 0 ]; then
        echo "  (none)"
    fi
    echo "---"
    echo "Use: sbx --init <name> to create a new sandbox"
}

status_sandbox() {
    local name="${1:-sandbox}"
    local path=$(get_sandbox_path "$name")

    if [ ! -d "$path" ]; then
        echo "Sandbox '$name' not found."
        return 1
    fi

    local size=$(du -sh "$path" 2>/dev/null | cut -f1)
    local version=$(cat "$path/etc/debian_version" 2>/dev/null)
    local pkg_count=$(ls "$path/var/cache/apt/archives/"*.deb 2>/dev/null | wc -l)

    echo "Sandbox: $name"
    echo "  Path:    $path"
    echo "  Size:    $size"
    echo "  Debian:  $version"
    echo "  Cached packages: $pkg_count"
}

run_in_sandbox() {
    local name="$1"
    shift
    local path=$(get_sandbox_path "$name")

    if [ ! -d "$path/etc" ]; then
        echo "Sandbox '$name' not found. Create it with: sbx --init $name"
        return 1
    fi

    # Sync network config
    cat /etc/resolv.conf > "$path/etc/resolv.conf" 2>/dev/null
    cat /etc/hosts > "$path/etc/hosts" 2>/dev/null

    exec fakeroot fakechroot chroot "$path" "$@"
}

# Parse arguments
SANDBOX_NAME="sandbox"

while true; do
    case "$1" in
        -n)
            SANDBOX_NAME="$2"
            shift 2
            ;;
        --init)
            init_sandbox "$2"
            exit $?
            ;;
        --rm)
            rm_sandbox "$2"
            exit $?
            ;;
        --rm-all)
            rm_all_sandboxes
            exit $?
            ;;
        --list|-l)
            list_sandboxes
            exit $?
            ;;
        --status|-s)
            status_sandbox "$2"
            exit $?
            ;;
        --help|-h)
            usage
            exit 0
            ;;
        -*)
            echo "Unknown option: $1"
            usage
            exit 1
            ;;
        *)
            break
            ;;
    esac
done

if [ $# -eq 0 ]; then
    usage
    exit 0
fi

run_in_sandbox "$SANDBOX_NAME" "$@"
